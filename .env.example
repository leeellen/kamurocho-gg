# --- Supabase (required) ---
# Project URL and service-role key from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Steam auth (required) ---
# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Random 32+ char secret used to sign the session cookie.
STEAM_SESSION_SECRET=

# --- App URL / session (required) ---
# Base URL of the app, used for the Steam OpenID return_to.
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=

# --- Report email notifications (optional) ---
# Gmail account + app password used to email new user reports.
GMAIL_USER=
GMAIL_APP_PASSWORD=
REPORT_NOTIFY_TO=

# --- Analytics / verification (optional) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
